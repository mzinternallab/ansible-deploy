# network --device=bond1 --vlanid=2042 --interfacename=bond1.2042 --no-activate --onboot=yes --noipv6 --ip={{network['external']['ip']}} --netmask={{network['external']['netmask']}} --gateway={{network['external']['gateway']}} --nameserver=10.149.2.36,10.149.2.37

#syspurpose --role="Red Hat Enterprise Linux Server" --sla="Standard" --usage="Production"
#url --url=https://rhn6.ornl.gov/pulp/content/Oak_Ridge_National_Lab/Library/content/dist/rhel9/9.3/x86_64/baseos/kickstart
