# Setup crypttab for data drive
#DATADRIVE_LUKS_UUID=$(blkid /dev/nvme0n1p1 -o value -s UUID)
#install -m 600 /dev/null /etc/datadrive.key
#openssl rand -base64 48 > /etc/datadrive.key
#cryptsetup luksChangeKey /dev/nvme0n1p1 /etc/datadrive.key --key-file <(echo -n "INSECURE-default-CHANGEME")
#sed -ri "s#(luks-$DATADRIVE_LUKS_UUID UUID=$DATADRIVE_LUKS_UUID) none#\\1 /etc/datadrive.key#" /etc/crypttab

# Setup clevis with PCR checking off on boot drive
ROOT_LUKS_DEVICE=$(pvs | grep systemvg | cut -f3 -d' ')
ROOT_BACK_DEVICE=$(cryptsetup status $ROOT_LUKS_DEVICE | grep device | cut -f2 -d: | xargs)
clevis luks bind -d $ROOT_BACK_DEVICE -k - <<<"INSECURE-default-CHANGEME" tpm2 '{"hash": "sha256", "key": "ecc"}'

# Clean up extra boot entries
ESP_DEVICE=$(grep /boot/efi /proc/mounts | cut -f1 -d' ')
ESP_UUID=$(blkid "${ESP_DEVICE}" -s PARTUUID -o value)
BOOT_OPTION=$(efibootmgr -v | grep "${ESP_UUID}" | cut -c 5-8)
for bootopt in $(efibootmgr -v | grep -E '^Boot[0-9]{4}' | grep 'HD('| cut -c 5-8); do
  if [[ $bootopt != $BOOT_OPTION ]]; then
    efibootmgr --delete-bootnum --bootnum $bootopt
  fi
done
efibootmgr --bootorder $BOOT_OPTION

%end

%post --nochroot --log=/mnt/sysimage/root/ks-post2.log --interpreter=/usr/bin/bash --erroronfail
set -xe -o pipefail

umask 022

rm /mnt/sysimage/etc/sysconfig/network-scripts/ifcfg-* -f
#cp /etc/sysconfig/network-scripts/ifcfg-* /mnt/sysimage/etc/sysconfig/network-scripts/

