# Kickstart for eagle-i
cmdline

# required settings
lang en_US.UTF-8
keyboard --xlayouts='us'
timezone Etc/UTC --utc --ntpservers=dmz-ntp.ornl.gov,dmz-ntp-alt.ornl.gov
# GIST initial password
rootpw --iscrypted $6$fjfExo/u9rTm4mbX$SxX9L/3EO94RdfsgYvKZVQqZqnsnMiVQdMp0jEfEBJrLU5UEXEkoCBseKgRRDuFuISiKCUYrjWuQ6vM64e2Wb0


# erase any existing partitions on local drives
#ignoredisk --only-use={{disk_path_ata}},nvme0n1,nvme1n1,nvme2n1,nvme3n1,nvme4n1
ignoredisk --only-use=disk/by-path/pci-0000:01:00.0-nvme-1,nvme0n1,nvme1n1,nvme2n1
#clearpart --drives=disk/by-path/pci-0000:18:00.0-sas-phy6-lun-0,{{disk_path_ata}},nvme0n1,nvme1n1,nvme2n1,nvme3n1,nvme4n1 --all
clearpart --drives=disk/by-path/pci-0000:01:00.0-nvme-1,disk/by-path/pci-0000:ca:00.0-nvme-1,disk/by-path/pci-0000:cb:00.0-nvme-1 --all
reqpart
#part /boot --ondisk={{disk_path_ata}} --size=1024 --fstype=xfs
part /boot --ondisk=disk/by-path/pci-0000:01:00.0-nvme-1 --size=1024 --fstype=xfs
part /boot/efi --ondisk=disk/by-path/pci-0000:01:00.0-nvme-1
#part pv.1 --ondisk={{disk_path_ata}} --grow --encrypted --passphrase=INSECURE-default-CHANGEME
part pv.1 --ondisk=disk/by-path/pci-0000:01:00.0-nvme-1 --grow --encrypted --passphrase=INSECURE-default-CHANGEME

# Create partition for software raid for stand-a-lone nvme's:
part raid.nvmeA --ondisk=disk/by-path/pci-0000:ca:00.0-nvme-1 --grow
part raid.nvmeB --ondisk=disk/by-path/pci-0000:cb:00.0-nvme-1 --grow
raid pv.2 --device md0 --level=RAID1 raid.nvmeA raid.nvmeB

volgroup systemvg pv.1
logvol / --vgname=systemvg --name=root --size=51200
logvol /home --vgname=systemvg --name=home --size=30720
logvol /var --vgname=systemvg --name=var --size=22528
logvol /var/tmp --vgname=systemvg --name=var_tmp --size=10240
logvol /var/log/audit --vgname=systemvg --name=var_log_audit --size=512


#part pv.2 --ondisk=nvme0n1 --grow --encrypted --passphrase=INSECURE-default-CHANGEME
#volgroup datavg pv.2
#logvol /var/lib/rancher/rke2/agent/containerd --vgname=datavg --name=containerd --size=102400
#logvol /var/lib/rook --vgname=datavg --name=var_lib_rook --size=20480

# Create volume group and LVM from RAID-1 device created above:
volgroup datavg pv.2
logvol /var/lib/rancher --vgname=datavg --name=rancher --size=204800
#logvol /var/lib/rook --vgname=datavg --name=var_lib_rook --size=20480

# MBR actually means ESP here
bootloader --location mbr

# We create both bonds here, but we don't activate both, since the rules we need can't be expressed here
#network --device=bond0 --bondslaves=eno3,eno4 --bondopts=mode=802.3ad,downdelay=0,miimon=1,updelay=0 --noipv4 --noipv6 --no-activate --onboot=yes
#network --device=bond1 --bondslaves=eno1,eno2 --bondopts=mode=802.3ad,downdelay=0,miimon=1,updelay=0 --noipv4 --noipv6 --no-activate --onboot=yes

